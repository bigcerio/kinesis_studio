# Database (Postgres) — es. Supabase, Neon, o Prisma Postgres
# DATABASE_URL: connessione pooled (pgbouncer), usata a runtime dall'app.
# DIRECT_URL: connessione diretta, usata da Prisma Migrate/CLI.
DATABASE_URL="postgresql://user:password@host:6543/dbname?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/dbname"

# Auth.js
AUTH_SECRET="genera con: npx auth secret"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Stripe Price IDs — crea 3 prodotti/prezzi ricorrenti nella dashboard Stripe
STRIPE_PRICE_MONTHLY=""
STRIPE_PRICE_SEMIANNUAL=""
STRIPE_PRICE_ANNUAL=""
